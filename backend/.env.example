# MongoDB URI (get from MongoDB Atlas)
# Example: mongodb+srv://user:password@cluster.xxxxx.mongodb.net/autopost
MONGO_URI=

# Encryption key for AES-256 (any random string, e.g. 32-64 characters)
ENCRYPTION_KEY=your_secret_encryption_key_here

# JWT Secret for future authentication (random string)
JWT_SECRET=your_jwt_secret_here

# Frontend URL for CORS (e.g. your Vercel URL)
FRONTEND_URL=http://localhost:5173

# Port to listen on (Railway sets this automatically)
PORT=3000
