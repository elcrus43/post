# ===========================================
# AutoPost - Production Environment (Railway)
# ===========================================
# ⚠️ НЕ КОММИТЬТЕ ЭТОТ ФАЙЛ В GIT!
# Настройте эти переменные в Railway Dashboard

# --- MongoDB ---
# MongoDB Atlas connection string (уже настроено в Railway)
# MONGO_URI=mongodb://user:password@cluster.mongodb.net/autopost?ssl=true&authSource=admin
MONGO_URI=

# --- Security ---
# Сгенерировать ключ: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
# Сгенерировать пароль: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_PASSWORD=

# --- Server ---
PORT=3000

# --- CORS ---
# URL вашего приложения на Railway
FRONTEND_URL=https://your-app.railway.app

# --- Environment ---
NODE_ENV=production

# --- VK OAuth ---
# https://vk.com/dev → Создать приложение
VK_CLIENT_ID=
VK_CLIENT_SECRET=
VK_REDIRECT_URI=https://your-app.railway.app/api/auth/vk/callback

# --- OK OAuth ---
# https://apiok.ru/dev → Создать приложение
OK_APP_ID=
OK_SECRET_KEY=
OK_PUBLIC_KEY=
OK_REDIRECT_URI=https://your-app.railway.app/api/auth/ok/callback

# --- TenChat OAuth (опционально) ---
TENCHAT_CLIENT_ID=
TENCHAT_CLIENT_SECRET=
TENCHAT_REDIRECT_URI=https://your-app.railway.app/api/auth/tenchat/callback

# --- Twitter/X OAuth (опционально) ---
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=https://your-app.railway.app/api/auth/twitter/callback
